<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvSubscriptionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Abonnement"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A1D2E"
            android:gravity="center"
            android:layout_marginTop="40dp" />

        <TextView
            android:id="@+id/tvSubscriptionPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="5$ / cours"
            android:textSize="20sp"
            android:textColor="#5B6BF8"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            android:layout_marginTop="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Informations de paiement"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1A1D2E" />

                <EditText
                    android:id="@+id/etCardNumber"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Numéro de carte (16 chiffres)"
                    android:inputType="number"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/edittext_background"
                    android:padding="12dp" />

                <EditText
                    android:id="@+id/etCardHolder"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Nom du titulaire"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/edittext_background"
                    android:padding="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <EditText
                        android:id="@+id/etExpiryDate"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:hint="MM/AA"
                        android:inputType="number"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/edittext_background"
                        android:padding="12dp" />

                    <EditText
                        android:id="@+id/etCvv"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:hint="CVV (3 chiffres)"
                        android:inputType="number"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/edittext_background"
                        android:padding="12dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnSubscribe"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Payer 5$"
                    android:backgroundTint="#5B6BF8"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>