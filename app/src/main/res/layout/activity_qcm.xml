<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6FA">

    <!-- ═══════════════════════════════
         FIXED HEADER
    ═══════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#5B6BF8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="‹"
                    android:textSize="22sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="#4A5AE8"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="QUIZ"
                    android:textSize="11sp"
                    android:textColor="#BFC5FB"
                    android:letterSpacing="0.12"
                    android:layout_marginStart="14dp" />

                <TextView
                    android:id="@+id/tvChapterBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 3/4"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#5B6BF8"
                    android:background="#FFFFFF"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvStepTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Test your knowledge"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="14dp" />

            <TextView
                android:id="@+id/tvStepSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pick the correct answer"
                android:textSize="13sp"
                android:textColor="#BFC5FB"
                android:layout_marginTop="4dp" />

            <!-- Step segment progress bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="22dp">

                <View
                    android:id="@+id/step1"
                    android:layout_width="0dp"
                    android:layout_height="5dp"
                    android:layout_weight="1"
                    android:background="#FFFFFF" />

                <View android:layout_width="6dp" android:layout_height="1dp" />

                <View
                    android:id="@+id/step2"
                    android:layout_width="0dp"
                    android:layout_height="5dp"
                    android:layout_weight="1"
                    android:background="#FFFFFF" />

                <View android:layout_width="6dp" android:layout_height="1dp" />

                <View
                    android:id="@+id/step3"
                    android:layout_width="0dp"
                    android:layout_height="5dp"
                    android:layout_weight="1"
                    android:background="#FFFFFF" />

                <View android:layout_width="6dp" android:layout_height="1dp" />

                <View
                    android:id="@+id/step4"
                    android:layout_width="0dp"
                    android:layout_height="5dp"
                    android:layout_weight="1"
                    android:background="#4A5AE8" />

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══════════════════════════════
         SCROLLABLE CONTENT
    ═══════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp">

            <!-- Question card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Question"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#5B6BF8"
                            android:background="#E8EAFD"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:letterSpacing="0.06" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <!-- Question number -->
                        <TextView
                            android:id="@+id/tvQuestionNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1 / 1"
                            android:textSize="12sp"
                            android:textColor="#8A8FA8" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F1FB"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="14dp" />

                    <TextView
                        android:id="@+id/tvQuestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading question..."
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#1A1D2E"
                        android:lineSpacingMultiplier="1.5" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Options -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="14dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/optionA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="18dp">
                        <TextView android:layout_width="32dp" android:layout_height="32dp" android:text="A" android:textSize="13sp" android:textStyle="bold" android:textColor="#5B6BF8" android:gravity="center" android:background="#E8EAFD" />
                        <TextView android:id="@+id/tvOptionA" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="14dp" android:text="Option A" android:textSize="15sp" android:textColor="#3A3D50" android:fontFamily="monospace" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/optionB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="18dp">
                        <TextView android:layout_width="32dp" android:layout_height="32dp" android:text="B" android:textSize="13sp" android:textStyle="bold" android:textColor="#5B6BF8" android:gravity="center" android:background="#E8EAFD" />
                        <TextView android:id="@+id/tvOptionB" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="14dp" android:text="Option B" android:textSize="15sp" android:textColor="#3A3D50" android:fontFamily="monospace" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/optionC"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="18dp">
                        <TextView android:layout_width="32dp" android:layout_height="32dp" android:text="C" android:textSize="13sp" android:textStyle="bold" android:textColor="#5B6BF8" android:gravity="center" android:background="#E8EAFD" />
                        <TextView android:id="@+id/tvOptionC" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="14dp" android:text="Option C" android:textSize="15sp" android:textColor="#3A3D50" android:fontFamily="monospace" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/optionD"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="18dp">
                        <TextView android:layout_width="32dp" android:layout_height="32dp" android:text="D" android:textSize="13sp" android:textStyle="bold" android:textColor="#5B6BF8" android:gravity="center" android:background="#E8EAFD" />
                        <TextView android:id="@+id/tvOptionD" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="14dp" android:text="Option D" android:textSize="15sp" android:textColor="#3A3D50" android:fontFamily="monospace" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Result card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A1D2E">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:id="@+id/tvResultIcon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textSize="16sp" android:textColor="#4CAF50" />
                        <TextView android:id="@+id/tvResultLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  Correct!" android:textSize="14sp" android:textStyle="bold" android:textColor="#4CAF50" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2D3E" android:layout_marginTop="12dp" android:layout_marginBottom="12dp" />
                    <TextView android:id="@+id/tvResultExplanation" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Explanation here..." android:textSize="14sp" android:textColor="#8A8FA8" android:lineSpacingMultiplier="1.65" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- FIXED BOTTOM BUTTON -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F5F6FA"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="28dp"
        android:elevation="8dp">

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8E9F3" android:layout_marginBottom="12dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/btnCheck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#5B6BF8">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:paddingTop="18dp" android:paddingBottom="18dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Check Answer" android:textSize="16sp" android:textStyle="bold" android:textColor="#FFFFFF" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A1D2E">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:paddingTop="18dp" android:paddingBottom="18dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Continue" android:textSize="16sp" android:textStyle="bold" android:textColor="#FFFFFF" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  →" android:textSize="18sp" android:textColor="#BFC5FB" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</LinearLayout>